              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>XIPHOSR</name>
          <description>QSPI XIP Hold Off Select Register</description>
          <addressOffset>0x0048</addressOffset>
