            <field>
              <name>MSK</name>
              <description>Always '3'.</description>
              <bitOffset>17</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SKIP</name>
              <description>This bit selects whether the address phase is to be skipped or not on the next QSPI transaction</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DDR</name>
              <description>This bit selects whether the address phase is executed in DDR mode (using both edges of the output clock)</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MODE</name>
              <description>This field selects the number of lines to use for the address output</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Single</name>
                  <description>Single (x1, 1-bits)</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Dual</name>
                  <description>Dual (x2, 2-bits)</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Quad</name>
                  <description>Quad (x4, 4-bits)</description>
                  <value>4</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DUR</name>
              <description>This field must reflect the length of the address phase of the QSPI transaction in QSPI clock cycles minus 1</description>
