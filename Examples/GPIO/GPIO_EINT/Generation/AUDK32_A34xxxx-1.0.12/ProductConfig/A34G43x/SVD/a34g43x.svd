                </enumeratedValue>
                <enumeratedValue>
                  <name>DISTURBED</name>
                  <description>Transmission error. Re-transmission may take place with respect to RETLIM[2:0] bits in CANFDn_PTDCR register</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>REJECTED</name>
                  <description>Misconfiguration of the frame format in the LLC frame.</description>
                  <value>6</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>HANDLE2</name>
