              <name>NO_WRLAT</name>
              <description>Always '1'.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SKIP</name>
              <description>This bit selects whether the dummy phase is to be skipped or not on the next QSPI transaction</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DUR</name>
              <description>This field reflects the length of the dummy phase of the SPI transaction in QSPI clock cycles minus 1</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
