                </enumeratedValue>
                <enumeratedValue>
                  <name>Quad</name>
                  <description>Quad (x4, 4-bits)</description>
                  <value>4</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DUR</name>
              <description>This field must reflect the length of the mode phase of XIP reads QSPI clock cycles minus 1</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
